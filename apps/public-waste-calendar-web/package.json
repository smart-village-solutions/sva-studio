{
  "name": "public-waste-calendar-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3002",
    "build": "pnpm exec tsx ../../scripts/ci/sync-injected-workspace-packages.ts . && rm -rf dist && vite build --outDir dist/client && pnpm exec tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/server/main.js",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@sva/core": "workspace:*",
    "@sva/data-repositories": "workspace:*",
    "@tabler/icons-react": "^3.41.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/react": "^16.2.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.8"
  }
}
