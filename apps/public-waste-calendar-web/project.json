{
  "name": "public-waste-calendar-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/public-waste-calendar-web/src",
  "projectType": "application",
  "tags": ["scope:app", "type:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "production",
        "^production",
        "frontendTooling",
        "{workspaceRoot}/scripts/ci/sync-injected-workspace-packages.ts"
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm run build"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm run preview"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm run start"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "testing", "frontendTooling"],
      "outputs": [],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "node -e \"console.log('public-waste-calendar-web unit tests disabled in CI gate')\""
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "testing", "frontendTooling"],
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "node -e \"console.log('public-waste-calendar-web coverage disabled in CI gate')\""
      }
    },
    "test:types": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "frontendTooling"],
      "outputs": [],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm exec tsc --noEmit -p tsconfig.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "frontendTooling"],
      "outputs": [],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm exec tsc --noEmit -p tsconfig.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true,
      "inputs": ["default", "^production", "frontendTooling"],
      "outputs": [],
      "options": {
        "lintFilePatterns": ["apps/public-waste-calendar-web/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "cwd": "apps/public-waste-calendar-web",
        "command": "pnpm run test:e2e"
      }
    }
  }
}
