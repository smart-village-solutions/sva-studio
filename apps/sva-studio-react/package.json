{
  "name": "sva-studio-react",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "builder:launch": "npx builder.io@latest launch -p 3000 -c \"pnpm nx run sva-studio-react:serve\" --no-open --workspace ./builder.workspace.json",
    "check:i18n": "node --import tsx ../../scripts/ci/check-i18n-keys.ts",
    "check:account-ui-foundation": "node --import tsx ../../scripts/ci/check-account-ui-foundation.ts",
    "build": "pnpm run check:i18n && pnpm run check:account-ui-foundation && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sva/auth": "workspace:*",
    "@sva/core": "workspace:*",
    "@sva/plugin-example": "workspace:*",
    "@sva/routing": "workspace:*",
    "@sva/sdk": "workspace:*",
    "@sva/sva-mainserver": "workspace:*",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-devtools": "^0.10.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "nitro": "^3.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "^1.9.1",
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "web-vitals": "^5.1.0"
  }
}
