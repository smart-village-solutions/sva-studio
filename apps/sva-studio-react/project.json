{
  "name": "sva-studio-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/sva-studio-react/src",
  "projectType": "application",
  "tags": [
    "scope:app",
    "type:app"
  ],
  "targets": {
    "check:i18n": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/scripts/ci/check-i18n-keys.ts"
      ],
      "outputs": [],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "bash ../../scripts/ci/run-workspace-node.sh --import tsx ../../scripts/ci/check-i18n-keys.ts"
      }
    },
    "check:account-ui-foundation": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/scripts/ci/check-account-ui-foundation.ts"
      ],
      "outputs": [],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "bash ../../scripts/ci/run-workspace-node.sh --import tsx ../../scripts/ci/check-account-ui-foundation.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "continuous": true,
      "inputs": [
        "default",
        "^production",
        "frontendTooling",
        "frontendEnvServe"
      ],
      "outputs": [],
      "options": {
        "buildTarget": "sva-studio-react:build",
        "port": 3000
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": [
        "check:toolchain-consistency",
        "check:i18n",
        "check:account-ui-foundation"
      ],
      "inputs": [
        "production",
        "^production",
        "frontendTooling",
        "frontendEnvBuild",
        "{workspaceRoot}/scripts/ci/patch-runtime-artifact.ts",
        "{workspaceRoot}/scripts/ci/run-workspace-node.sh"
      ],
      "outputs": [
        "{projectRoot}/.output"
      ],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "bash ../../scripts/ci/run-workspace-node.sh -e \"require('node:fs').mkdirSync('.output/server',{recursive:true})\" && pnpm exec vite build && bash ../../scripts/ci/run-workspace-node.sh --import tsx ../../scripts/ci/patch-runtime-artifact.ts ."
      }
    },
    "check:toolchain-consistency": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "command": "bash scripts/ci/run-workspace-node.sh --import tsx scripts/ci/check-toolchain-consistency.ts"
      }
    },
    "verify:runtime-artifact": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "{workspaceRoot}/artifacts/runtime/runtime-artifact-verify"
      ],
      "options": {
        "command": "bash scripts/ci/verify-runtime-artifact.sh apps/sva-studio-react artifacts/runtime/runtime-artifact-verify"
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "continuous": true,
      "outputs": [],
      "options": {
        "buildTarget": "sva-studio-react:build",
        "port": 4173
      }
    },
    "test:unit": {
      "executor": "@nx/vitest:test",
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "testing",
        "frontendTooling"
      ],
      "outputs": [],
      "options": {
        "configFile": "apps/sva-studio-react/vitest.config.ts"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "parallelism": false,
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "testing",
        "frontendTooling"
      ],
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "pnpm exec vitest run --coverage --reporter=verbose --config vitest.config.ts"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "node -e \"console.log('no integration tests configured for sva-studio-react')\""
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "frontendTooling"
      ],
      "outputs": [],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "pnpm exec tsc --noEmit -p tsconfig.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "frontendTooling"
      ],
      "outputs": [],
      "options": {
        "lintFilePatterns": [
          "apps/sva-studio-react/src/**/*.{ts,tsx,js,jsx}",
          "apps/sva-studio-react/e2e/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test:e2e": {
      "executor": "@nx/playwright:playwright",
      "cache": true,
      "dependsOn": [
        {
          "projects": [
            "core"
          ],
          "target": "build"
        }
      ],
      "inputs": [
        "default",
        "^production",
        "frontendTooling",
        "frontendEnvE2E",
        "frontendEnvServe"
      ],
      "outputs": [
        "{projectRoot}/playwright-report",
        "{projectRoot}/test-results"
      ],
      "options": {
        "config": "apps/sva-studio-react/playwright.config.ts",
        "skipInstall": true
      }
    },
    "test:acceptance": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "cwd": "apps/sva-studio-react",
        "command": "bash ../../scripts/ci/run-workspace-node.sh --import tsx ../../scripts/ci/run-iam-acceptance.ts"
      }
    }
  }
}
