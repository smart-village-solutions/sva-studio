{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["src/routes/__debug/**/*"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sva/core": ["../../packages/core/src/index.ts"],
      "@sva/data": ["../../packages/data/src/index.ts"],
      "@sva/auth-runtime": ["../../packages/auth-runtime/src/index.ts"],
      "@sva/auth-runtime/server": ["../../packages/auth-runtime/src/server.ts"],
      "@sva/auth": ["../../packages/auth/src/index.ts"],
      "@sva/auth/server": ["../../packages/auth/dist/index.server.d.ts"],
      "@sva/plugin-sdk": ["../../packages/plugin-sdk/src/index.ts"],
      "@sva/sdk": ["../../packages/sdk/src/index.ts"],
      "@sva/sdk/logging": ["../../packages/sdk/src/logging.ts"],
      "@sva/server-runtime": ["../../packages/server-runtime/src/index.ts"],
      "@sva/plugin-news": ["../../packages/plugin-news/src/index.ts"]
    }
  }
}
