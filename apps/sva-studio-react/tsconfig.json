{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["src/routes/__debug/**/*"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sva/core": ["../../packages/core/src/index.ts"],
      "@sva/core/security": ["../../packages/core/src/security/index.ts"],
      "@sva/auth-runtime": ["../../packages/auth-runtime/src/index.ts"],
      "@sva/auth-runtime/routes": ["../../packages/auth-runtime/src/routes.ts"],
      "@sva/auth-runtime/runtime-health": ["../../packages/auth-runtime/src/runtime-health.ts"],
      "@sva/auth-runtime/runtime-routes": ["../../packages/auth-runtime/src/runtime-routes.ts"],
      "@sva/auth-runtime/server": ["../../packages/auth-runtime/dist/server.d.ts"],
      "@sva/data-repositories": ["../../packages/data-repositories/src/index.ts"],
      "@sva/data-repositories/server": ["../../packages/data-repositories/src/server.ts"],
      "@sva/iam-admin": ["../../packages/iam-admin/src/index.ts"],
      "@sva/iam-admin/encryption": ["../../packages/iam-admin/src/encryption.ts"],
      "@sva/iam-core": ["../../packages/iam-core/src/index.ts"],
      "@sva/iam-governance/legal-text-html": ["../../packages/iam-governance/src/legal-text-html.ts"],
      "@sva/iam-governance/legal-text-sanitize-html": ["../../packages/iam-governance/src/legal-text-sanitize-html.ts"],
      "@sva/plugin-categories": ["../../packages/plugin-categories/src/index.ts"],
      "@sva/plugin-events": ["../../packages/plugin-events/src/index.ts"],
      "@sva/plugin-waste-management": ["../../packages/plugin-waste-management/src/index.ts"],
      "@sva/plugin-waste-management/waste-management.job-definitions": [
        "../../packages/plugin-waste-management/src/waste-management.job-definitions.ts"
      ],
      "@sva/plugin-sdk": ["../../packages/plugin-sdk/src/index.ts"],
      "@sva/routing": ["../../packages/routing/src/index.ts"],
      "@sva/routing/server": ["../../packages/routing/src/index.server.ts"],
      "@sva/mail-runtime": ["../../packages/mail-runtime/src/index.ts"],
      "@sva/studio-module-iam": ["../../packages/studio-module-iam/src/index.ts"],
      "@sva/studio-ui-react": ["../../packages/studio-ui-react/src/index.ts"],
      "@sva/monitoring-client": ["../../packages/monitoring-client/src/index.ts"],
      "@sva/monitoring-client/logging": ["../../packages/monitoring-client/src/logging.ts"],
      "@sva/monitoring-client/server": ["../../packages/monitoring-client/src/server.ts"],
      "@sva/monitoring-client/logger-provider.server": ["../../packages/monitoring-client/src/logger-provider.server.ts"],
      "@sva/server-runtime": ["../../packages/server-runtime/src/index.ts"],
      "@sva/sva-mainserver": ["../../packages/sva-mainserver/src/index.ts"],
      "@sva/sva-mainserver/server": ["../../packages/sva-mainserver/src/index.server.ts"],
      "@sva/plugin-news": ["../../packages/plugin-news/src/index.ts"],
      "@sva/plugin-poi": ["../../packages/plugin-poi/src/index.ts"],
      "@sva/media": ["../../packages/media/src/index.ts"],
      "@sva/waste-management-runtime": ["../../packages/waste-management-runtime/src/index.ts"],
      "@sva/waste-management-runtime/server": ["../../packages/waste-management-runtime/src/server.ts"]
    }
  }
}
