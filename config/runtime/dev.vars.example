# GitHub-Environment "dev": Vorlage für das Secret APP_CONFIG.
# Vor dem ersten Deploy Realm und Clients gegen Keycloak verifizieren.

SVA_RUNTIME_PROFILE=studio
SVA_STACK_NAME=studio-dev
SVA_PUBLIC_BASE_URL=https://studio-dev.smart-village.app
SVA_PARENT_DOMAIN=studio-dev.smart-village.app
SVA_ALLOWED_INSTANCE_IDS=
SVA_AUTH_ISSUER=__SET_DEV_AUTH_ISSUER__
SVA_AUTH_CLIENT_ID=sva-studio
SVA_AUTH_REDIRECT_URI=https://studio-dev.smart-village.app/auth/callback
SVA_AUTH_POST_LOGOUT_REDIRECT_URI=https://studio-dev.smart-village.app/
IAM_CSRF_ALLOWED_ORIGINS=https://studio-dev.smart-village.app
KEYCLOAK_ADMIN_BASE_URL=https://keycloak.smart-village.app
KEYCLOAK_ADMIN_REALM=__SET_DEV_ADMIN_REALM__
KEYCLOAK_ADMIN_CLIENT_ID=sva-studio-iam-service
KEYCLOAK_PROVISIONER_BASE_URL=https://keycloak.smart-village.app
KEYCLOAK_PROVISIONER_REALM=master
KEYCLOAK_PROVISIONER_CLIENT_ID=sva-studio-provisioner
POSTGRES_DB=sva_studio
POSTGRES_USER=sva
APP_DB_USER=sva_app
IAM_PII_ACTIVE_KEY_ID=k1
IAM_UI_ENABLED=true
IAM_ADMIN_ENABLED=true
IAM_BULK_ENABLED=true
VITE_IAM_UI_ENABLED=true
VITE_IAM_ADMIN_ENABLED=true
VITE_IAM_BULK_ENABLED=true
IAM_DEBUG_PROFILE_ERRORS=false
SVA_ENABLE_SERVER_CONSOLE_LOGS=true
SVA_AUTH_DEBUG_HEADERS=false
SVA_KEYCLOAK_PROVISIONER_POLL_INTERVAL_MS=5000

# Secrets: ausschließlich in dev.local.vars und im GitHub-Secret APP_CONFIG.
SVA_AUTH_CLIENT_SECRET=__SET_DEV_AUTH_CLIENT_SECRET__
SVA_AUTH_STATE_SECRET=__SET_DEV_AUTH_STATE_SECRET__
KEYCLOAK_ADMIN_CLIENT_SECRET=__SET_DEV_ADMIN_CLIENT_SECRET__
KEYCLOAK_PROVISIONER_CLIENT_SECRET=__SET_DEV_PROVISIONER_CLIENT_SECRET__
POSTGRES_PASSWORD=__SET_DEV_POSTGRES_PASSWORD__
APP_DB_PASSWORD=__SET_DEV_APP_DB_PASSWORD__
REDIS_PASSWORD=__SET_DEV_REDIS_PASSWORD__
ENCRYPTION_KEY=__SET_DEV_ENCRYPTION_KEY__
IAM_PII_KEYRING_JSON=__SET_DEV_PII_KEYRING_JSON__
