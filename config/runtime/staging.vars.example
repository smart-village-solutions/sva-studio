# GitHub-Environment "staging": Vorlage für das Secret APP_CONFIG.
# Nicht committen: Die aktive Kopie liegt in staging.local.vars.

SVA_RUNTIME_PROFILE=studio
SVA_STACK_NAME=studio-staging
SVA_PUBLIC_BASE_URL=https://studio-staging.smart-village.app
SVA_PARENT_DOMAIN=studio-staging.smart-village.app
SVA_ALLOWED_INSTANCE_IDS=
SVA_AUTH_ISSUER=https://keycloak.smart-village.app/realms/studio-staging
SVA_STUDIO_MCP_ENABLED=false
SVA_STUDIO_MCP_ISSUER=https://keycloak.smart-village.app/realms/studio-staging
SVA_STUDIO_MCP_AUDIENCE=sva-studio-mcp
SVA_STUDIO_MCP_CLIENT_ID=sva-studio-mcp
SVA_AUTH_CLIENT_ID=sva-studio
SVA_AUTH_REDIRECT_URI=https://studio-staging.smart-village.app/auth/callback
SVA_AUTH_POST_LOGOUT_REDIRECT_URI=https://studio-staging.smart-village.app/
IAM_CSRF_ALLOWED_ORIGINS=https://studio-staging.smart-village.app
KEYCLOAK_ADMIN_BASE_URL=https://keycloak.smart-village.app
KEYCLOAK_ADMIN_REALM=studio-staging
KEYCLOAK_ADMIN_CLIENT_ID=sva-studio-iam-service
KEYCLOAK_PROVISIONER_BASE_URL=https://keycloak.smart-village.app
KEYCLOAK_PROVISIONER_REALM=master
KEYCLOAK_PROVISIONER_CLIENT_ID=sva-studio-provisioner
POSTGRES_DB=sva_studio
POSTGRES_USER=sva
APP_DB_USER=sva_app
IAM_PII_ACTIVE_KEY_ID=k1
IAM_UI_ENABLED=true
IAM_ADMIN_ENABLED=true
IAM_BULK_ENABLED=true
VITE_IAM_UI_ENABLED=true
VITE_IAM_ADMIN_ENABLED=true
VITE_IAM_BULK_ENABLED=true
IAM_DEBUG_PROFILE_ERRORS=false
SVA_ENABLE_SERVER_CONSOLE_LOGS=true
SVA_AUTH_DEBUG_HEADERS=false
SVA_KEYCLOAK_PROVISIONER_POLL_INTERVAL_MS=5000

# Secrets: ausschließlich in staging.local.vars und im GitHub-Secret APP_CONFIG.
SVA_AUTH_CLIENT_SECRET=__SET_STAGING_AUTH_CLIENT_SECRET__
SVA_AUTH_STATE_SECRET=__SET_STAGING_AUTH_STATE_SECRET__
KEYCLOAK_ADMIN_CLIENT_SECRET=__SET_STAGING_ADMIN_CLIENT_SECRET__
KEYCLOAK_PROVISIONER_CLIENT_SECRET=__SET_STAGING_PROVISIONER_CLIENT_SECRET__
POSTGRES_PASSWORD=__SET_STAGING_POSTGRES_PASSWORD__
APP_DB_PASSWORD=__SET_STAGING_APP_DB_PASSWORD__
REDIS_PASSWORD=__SET_STAGING_REDIS_PASSWORD__
ENCRYPTION_KEY=__SET_STAGING_ENCRYPTION_KEY__
IAM_PII_KEYRING_JSON=__SET_STAGING_PII_KEYRING_JSON__
