# Externer Port des App-Containers auf dem Server.
# (Nur im Nicht-Swarm-Betrieb relevant; in Swarm routet Traefik.)
APP_PORT=3000

# Name der Anwendungsdatenbank in Postgres.
POSTGRES_DB=sva_studio
# Administrativer Postgres-User, den der Container beim Init verwendet.
POSTGRES_USER=sva
# Dedizierter Laufzeit-User der App für DB-Zugriffe ohne Superuser-Rechte.
APP_DB_USER=sva_app

# ---------------------------------------------------------------------------
# Registry-/Image-Konfiguration (Swarm-Modus)
# ---------------------------------------------------------------------------
# Container-Registry für das vorgebaute App-Image.
SVA_REGISTRY=ghcr.io/smart-village-solutions
# Repository-Name des App-Images innerhalb der Registry.
SVA_IMAGE_REPOSITORY=sva-studio
# Registry für das Monitoring-Init-Image.
SVA_MONITORING_REGISTRY=ghcr.io/smart-village-solutions
# Image-Tag oder Digest; für Produktion Immutable-Tag oder Digest verwenden.
SVA_IMAGE_TAG=0.0.0-dev
SVA_IMAGE_DIGEST=sha256:__SET_IMMUTABLE_DIGEST__
SVA_IMAGE_REF=ghcr.io/smart-village-solutions/sva-studio@sha256:__SET_IMMUTABLE_DIGEST__
SVA_MONITORING_CONFIG_INIT_IMAGE_TAG=0.0.0-dev

# ---------------------------------------------------------------------------
# Instance-Routing
# ---------------------------------------------------------------------------
# Parent-Domain für Instanz-Subdomains, z. B. studio.smart-village.app
SVA_PARENT_DOMAIN=studio.smart-village.app
# Kommagetrennte Liste erlaubter instanceIds (Kleinschreibung, keine Leerzeichen).
SVA_ALLOWED_INSTANCE_IDS=hb-meinquartier
# Kanonisches Betriebsprofil fuer diese Serverumgebung.
SVA_RUNTIME_PROFILE=acceptance-hb

# Öffentliche Basis-URL deiner Anwendung (kanonischer Auth-Host).
SVA_PUBLIC_BASE_URL=https://hb-meinquartier.studio.smart-village.app
# Expliziter Ingress-Host fuer Traefik, wenn der Acceptance-Host direkt geroutet werden soll.
SVA_PUBLIC_HOST=hb-meinquartier.studio.smart-village.app
# Separater, geschuetzter Host fuer Adminer auf der Acceptance-Instanz.
SVA_DB_ADMIN_HOST=hb-meinquartier-db.studio.smart-village.app
# OIDC-Issuer-URL deines Keycloak-Realms.
SVA_AUTH_ISSUER=https://keycloak.smart-village.app/realms/saas-hb-meinquartier
# OIDC-Client-ID für die normale Benutzeranmeldung.
SVA_AUTH_CLIENT_ID=sva-studio
# Exakte Callback-URL, die in Keycloak für den Client erlaubt sein muss.
SVA_AUTH_REDIRECT_URI=https://hb-meinquartier.studio.smart-village.app/auth/callback
# Ziel nach Logout aus der Anwendung.
SVA_AUTH_POST_LOGOUT_REDIRECT_URI=https://hb-meinquartier.studio.smart-village.app/
# Erlaubte Origins für CSRF-geschützte IAM-Schreibzugriffe.
IAM_CSRF_ALLOWED_ORIGINS=https://hb-meinquartier.studio.smart-village.app

# OpenTelemetry / Monitoring
ENABLE_OTEL=true
OTEL_SERVICE_NAME=sva-studio
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# Grafana bleibt intern; Passwort trotzdem explizit setzen.
GF_SECURITY_ADMIN_PASSWORD=change-me-before-deploy

# Backend-Feature-Flags für IAM/UI-Funktionen.
IAM_UI_ENABLED=true
IAM_ADMIN_ENABLED=true
IAM_BULK_ENABLED=true
# Frontend-Feature-Flags passend zu den Backend-Flags.
VITE_IAM_UI_ENABLED=true
VITE_IAM_ADMIN_ENABLED=true
VITE_IAM_BULK_ENABLED=true

# Basis-URL der Keycloak-Admin-API; erst nötig für Admin-/Sync-Funktionen.
KEYCLOAK_ADMIN_BASE_URL=https://keycloak.smart-village.app
# Realm für den Keycloak-Service-Account.
KEYCLOAK_ADMIN_REALM=saas-hb-meinquartier
# Client-ID des Keycloak-Service-Accounts für Admin-/Sync-Aufgaben.
KEYCLOAK_ADMIN_CLIENT_ID=sva-studio-iam-service
# Optionale Mainserver-Smoke-/Benchmark-Zugangsdaten fuer env:smoke:acceptance-hb.
SVA_MAINSERVER_GRAPHQL_URL=__SET_HB_MAINSERVER_GRAPHQL_URL__
SVA_MAINSERVER_OAUTH_TOKEN_URL=__SET_HB_MAINSERVER_OAUTH_TOKEN_URL__
SVA_MAINSERVER_CLIENT_ID=__SET_VIA_PORTAINER_OR_LOCAL_OVERRIDE__
SVA_MAINSERVER_CLIENT_SECRET=__SET_VIA_PORTAINER_OR_LOCAL_OVERRIDE__
# Intervall für automatische Rollenabgleiche in Millisekunden.
IAM_ROLE_RECONCILE_INTERVAL_MS=300000

# ---------------------------------------------------------------------------
# Sensible Variablen (im Acceptance-Profil direkt als Stack-Variablen setzen)
# ---------------------------------------------------------------------------
# Pflichtwerte:
#   POSTGRES_PASSWORD
#   APP_DB_PASSWORD
#   REDIS_PASSWORD
#   SVA_AUTH_CLIENT_SECRET
#   SVA_AUTH_STATE_SECRET
#   KEYCLOAK_ADMIN_CLIENT_SECRET
#   ENCRYPTION_KEY
#   IAM_PII_KEYRING_JSON
#   SVA_DB_ADMIN_BASIC_AUTH (htpasswd-Format fuer den vorgeschalteten Adminer-Basic-Auth-Schutz)
# Sie werden im aktuellen Acceptance-Profil nicht mehr über Docker-Secrets,
# sondern direkt über die Stack-Variablen in Portainer gesetzt.
# Kommagetrennte Instance-IDs für automatische Rollenabgleiche; leer = aus.
IAM_ROLE_RECONCILE_INSTANCE_IDS=
