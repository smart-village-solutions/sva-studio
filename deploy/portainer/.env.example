# Externer Port des App-Containers auf dem Server.
# (Nur im Nicht-Swarm-Betrieb relevant; in Swarm routet Traefik.)
APP_PORT=3000

# Name der Anwendungsdatenbank in Postgres.
POSTGRES_DB=sva_studio
# Administrativer Postgres-User, den der Container beim Init verwendet.
POSTGRES_USER=sva
# Dedizierter Laufzeit-User der App fuer DB-Zugriffe ohne Superuser-Rechte.
APP_DB_USER=sva_app

# ---------------------------------------------------------------------------
# Registry-/Image-Konfiguration (Swarm-Modus)
# ---------------------------------------------------------------------------
# Container-Registry fuer das vorgebaute App-Image.
SVA_REGISTRY=ghcr.io/smart-village-solutions
# Image-Tag oder Digest; fuer Produktion Immutable-Tag oder Digest verwenden.
SVA_IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Instance-Routing
# ---------------------------------------------------------------------------
# Parent-Domain fuer Instanz-Subdomains, z. B. studio.smart-village.app
SVA_PARENT_DOMAIN=studio.smart-village.app
# Kommagetrennte Liste erlaubter instanceIds (Kleinschreibung, keine Leerzeichen).
SVA_ALLOWED_INSTANCE_IDS=

# Oeffentliche Basis-URL deiner Anwendung (kanonischer Auth-Host).
SVA_PUBLIC_BASE_URL=https://studio.smart-village.app
# OIDC-Issuer-URL deines Keycloak-Realms.
SVA_AUTH_ISSUER=https://keycloak.example.org/realms/sva
# OIDC-Client-ID fuer die normale Benutzeranmeldung.
SVA_AUTH_CLIENT_ID=sva-studio
# Exakte Callback-URL, die in Keycloak fuer den Client erlaubt sein muss.
SVA_AUTH_REDIRECT_URI=https://studio.smart-village.app/auth/callback
# Ziel nach Logout aus der Anwendung.
SVA_AUTH_POST_LOGOUT_REDIRECT_URI=https://studio.smart-village.app/
# Erlaubte Origins fuer CSRF-geschuetzte IAM-Schreibzugriffe.
IAM_CSRF_ALLOWED_ORIGINS=https://studio.smart-village.app

# OpenTelemetry im ersten Schritt ausgeschaltet lassen.
ENABLE_OTEL=false

# Backend-Feature-Flags fuer IAM/UI-Funktionen.
IAM_UI_ENABLED=false
IAM_ADMIN_ENABLED=false
IAM_BULK_ENABLED=false
# Frontend-Feature-Flags passend zu den Backend-Flags.
VITE_IAM_UI_ENABLED=false
VITE_IAM_ADMIN_ENABLED=false
VITE_IAM_BULK_ENABLED=false

# Basis-URL der Keycloak-Admin-API; erst noetig fuer Admin-/Sync-Funktionen.
KEYCLOAK_ADMIN_BASE_URL=https://keycloak.example.org
# Realm fuer den Keycloak-Service-Account.
KEYCLOAK_ADMIN_REALM=sva
# Client-ID des Keycloak-Service-Accounts fuer Admin-/Sync-Aufgaben.
KEYCLOAK_ADMIN_CLIENT_ID=sva-studio-iam-service
# Intervall fuer automatische Rollenabgleiche in Millisekunden.
IAM_ROLE_RECONCILE_INTERVAL_MS=300000

# ---------------------------------------------------------------------------
# Secrets (im Swarm-Modus als Docker-Secrets bereitstellen)
# ---------------------------------------------------------------------------
# Die folgenden Werte werden im Swarm-Betrieb NICHT als Env-Variablen gesetzt,
# sondern als externe Docker-Secrets provisioniert. Namenskonvention:
#
#   sva_studio_app_auth_client_secret    -> SVA_AUTH_CLIENT_SECRET
#   sva_studio_app_auth_state_secret     -> SVA_AUTH_STATE_SECRET
#   sva_studio_app_encryption_key        -> ENCRYPTION_KEY
#   sva_studio_app_pii_keyring_json      -> IAM_PII_KEYRING_JSON
#   sva_studio_app_db_password           -> APP_DB_PASSWORD
#   sva_studio_postgres_password         -> POSTGRES_PASSWORD
#   sva_studio_keycloak_admin_client_secret -> KEYCLOAK_ADMIN_CLIENT_SECRET
#
# Erstellen: docker secret create sva_studio_app_auth_client_secret <secret-file>
# Details:   docs/guides/swarm-deployment-runbook.md
# Kommagetrennte Instance-IDs fuer automatische Rollenabgleiche; leer = aus.
IAM_ROLE_RECONCILE_INSTANCE_IDS=
