{
  "name": "sva-studio",
  "version": "0.0.1",
  "description": "![Mockup 01 2026](docs/images/mockup-01-2026.png)",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.12.2"
  },
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "nx": "env -u NO_COLOR nx",
    "build": "env -u NO_COLOR nx run-many -t build",
    "lint": "env -u NO_COLOR nx run-many -t lint",
    "test:eslint": "env -u NO_COLOR nx run-many -t lint",
    "test:types": "env -u NO_COLOR nx run-many -t build --projects=auth,core,data,monitoring-client,plugin-example,routing,sdk,sva-mainserver && env -u NO_COLOR nx run sva-studio-react:typecheck && pnpm exec tsc -p tsconfig.scripts.json --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "env -u NO_COLOR nx run-many -t test:unit --parallel=1",
    "test:coverage": "env -u NO_COLOR nx run-many -t test:coverage",
    "test:coverage:affected": "env -u NO_COLOR nx affected --target=test:coverage --base=origin/main",
    "test:coverage:pr": "pnpm test:coverage:affected && pnpm patch-coverage-gate --base=origin/main",
    "test:integration": "env -u NO_COLOR nx run-many -t test:integration",
    "test:e2e": "env -u NO_COLOR nx run sva-studio-react:test:e2e",
    "test:acceptance:iam": "env -u NO_COLOR nx run sva-studio-react:test:acceptance",
    "test:ci": "pnpm check:file-placement && pnpm check:openapi:iam && pnpm test:types && pnpm test:unit && pnpm test:coverage && pnpm complexity-gate",
    "coverage-gate": "tsx scripts/ci/coverage-gate.ts",
    "patch-coverage-gate": "tsx scripts/ci/patch-coverage-gate.ts",
    "complexity-gate": "tsx scripts/ci/complexity-gate.ts",
    "clean:source-artifacts": "tsx scripts/ci/clean-source-artifacts.ts",
    "check:file-placement": "tsx scripts/ci/check-file-placement.ts",
    "check:file-placement:staged": "tsx scripts/ci/check-file-placement.ts --staged",
    "check:openapi:iam": "tsx scripts/ci/check-openapi-iam.ts",
    "env:up:local-keycloak": "tsx scripts/ops/runtime-env.ts up local-keycloak",
    "env:down:local-keycloak": "tsx scripts/ops/runtime-env.ts down local-keycloak",
    "env:update:local-keycloak": "tsx scripts/ops/runtime-env.ts update local-keycloak",
    "env:status:local-keycloak": "tsx scripts/ops/runtime-env.ts status local-keycloak",
    "env:smoke:local-keycloak": "tsx scripts/ops/runtime-env.ts smoke local-keycloak",
    "env:migrate:local-keycloak": "tsx scripts/ops/runtime-env.ts migrate local-keycloak",
    "env:doctor:local-keycloak": "tsx scripts/ops/runtime-env.ts doctor local-keycloak",
    "env:up:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts up local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:down:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts down local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:update:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts update local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:status:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts status local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:smoke:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts smoke local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:migrate:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts migrate local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:doctor:local-keycloak:hb": "tsx scripts/ops/runtime-env.ts doctor local-keycloak --local-override-file=config/runtime/local-keycloak.hb.local.vars",
    "env:bootstrap:local-instance-db": "tsx scripts/ops/bootstrap-local-instance-db.ts",
    "env:up:local-keycloak:hb:docker": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml -f docker-compose.local-hb-app.yml --profile hb-app up -d app-hb",
    "env:down:local-keycloak:hb:docker": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml -f docker-compose.local-hb-app.yml --profile hb-app stop app-hb",
    "env:status:local-keycloak:hb:docker": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml -f docker-compose.local-hb-app.yml --profile hb-app ps app-hb",
    "env:up:local-builder": "tsx scripts/ops/runtime-env.ts up local-builder",
    "env:down:local-builder": "tsx scripts/ops/runtime-env.ts down local-builder",
    "env:update:local-builder": "tsx scripts/ops/runtime-env.ts update local-builder",
    "env:status:local-builder": "tsx scripts/ops/runtime-env.ts status local-builder",
    "env:smoke:local-builder": "tsx scripts/ops/runtime-env.ts smoke local-builder",
    "env:migrate:local-builder": "tsx scripts/ops/runtime-env.ts migrate local-builder",
    "env:doctor:local-builder": "tsx scripts/ops/runtime-env.ts doctor local-builder",
    "env:up:acceptance-hb": "tsx scripts/ops/runtime-env.ts up acceptance-hb",
    "env:down:acceptance-hb": "tsx scripts/ops/runtime-env.ts down acceptance-hb",
    "env:update:acceptance-hb": "tsx scripts/ops/runtime-env.ts update acceptance-hb",
    "env:status:acceptance-hb": "tsx scripts/ops/runtime-env.ts status acceptance-hb",
    "env:precheck:acceptance-hb": "tsx scripts/ops/runtime-env.ts precheck acceptance-hb",
    "env:deploy:acceptance-hb": "tsx scripts/ops/runtime-env.ts deploy acceptance-hb",
    "env:feedback:acceptance-hb": "tsx scripts/ops/deploy-feedback-loop.ts --latest",
    "env:smoke:acceptance-hb": "tsx scripts/ops/runtime-env.ts smoke acceptance-hb",
    "env:migrate:acceptance-hb": "tsx scripts/ops/runtime-env.ts migrate acceptance-hb",
    "env:reset:acceptance-hb": "tsx scripts/ops/runtime-env.ts reset acceptance-hb",
    "env:doctor:acceptance-hb": "tsx scripts/ops/runtime-env.ts doctor acceptance-hb",
    "schema-diff:sva-mainserver": "node scripts/ci/sva-mainserver-schema-diff.mjs",
    "benchmark:sva-mainserver": "node scripts/ops/benchmark-sva-mainserver.mjs",
    "iam:retention:run": "node scripts/ops/run-iam-retention.mjs",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smart-village-solutions/sva-studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/smart-village-solutions/sva-studio/issues"
  },
  "homepage": "https://github.com/smart-village-solutions/sva-studio#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^22.5.4",
    "@nx/eslint-plugin": "^22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/playwright": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "10.4.27",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "nx": "^22.5.4",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "undici": "7.24.3"
  },
  "pnpm": {
    "overrides": {
      "h3": "2.0.1-rc.16",
      "minimatch": "10.2.3",
      "axios": "1.13.5",
      "rollup": "4.59.0",
      "undici": "7.24.3",
      "solid-js": "1.9.11",
      "seroval": "1.4.2"
    }
  }
}
