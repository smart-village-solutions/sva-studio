{
  "name": "sva-studio",
  "version": "0.0.1",
  "description": "![Mockup 01 2026](docs/images/mockup-01-2026.png)",
  "private": true,
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.3.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "nx": "env -u NO_COLOR nx",
    "build": "pnpm clean:generated-source-artifacts && env -u NO_COLOR nx run-many -t build",
    "lint": "env -u NO_COLOR nx run-many -t lint",
    "test:eslint": "pnpm check:plugin-ui-boundary && pnpm check:plugin-architecture-boundary && env -u NO_COLOR nx run-many -t lint",
    "test:eslint:affected": "pnpm check:plugin-ui-boundary && pnpm check:plugin-architecture-boundary && env -u NO_COLOR nx affected --target=lint --base=${NX_BASE:-origin/main}",
    "test:types": "pnpm clean:generated-source-artifacts && env -u NO_COLOR nx run-many -t test:types --parallel=1 && env -u NO_COLOR nx run-many -t typecheck --parallel=1 && pnpm check:server-runtime && pnpm exec tsc -p tsconfig.scripts.json --noEmit",
    "test:types:affected": "pnpm clean:generated-source-artifacts && env -u NO_COLOR nx affected --target=test:types --base=${NX_BASE:-origin/main} --parallel=1 && env -u NO_COLOR nx affected --target=typecheck --base=${NX_BASE:-origin/main} --parallel=1 && pnpm check:server-runtime:affected && pnpm exec tsc -p tsconfig.scripts.json --noEmit",
    "test": "pnpm test:unit",
    "test:a11y": "env -u NO_COLOR nx run sva-studio-react:test:a11y",
    "test:unit": "env -u NO_COLOR nx run-many -t test:unit --parallel=1",
    "test:unit:affected": "tsx scripts/ci/affected-unit-gate.ts --base ${NX_BASE:-origin/main}",
    "test:coverage": "env -u NO_COLOR nx run-many -t test:coverage",
    "test:coverage:affected": "tsx scripts/ci/affected-coverage-gate.ts --base ${NX_BASE:-origin/main}",
    "test:coverage:pr": "pnpm test:coverage:affected && pnpm patch-coverage-gate --base=${NX_BASE:-origin/main} && pnpm sonar-new-code-gate --base=${NX_BASE:-origin/main}",
    "check:toolchain-consistency": "bash scripts/ci/run-workspace-node.sh --import tsx scripts/ci/check-toolchain-consistency.ts",
    "check:bot-comment-handling": "node --experimental-strip-types scripts/ci/check-bot-comment-handling.ts",
    "check:plugin-ui-boundary": "tsx scripts/ci/check-plugin-ui-boundary.ts",
    "check:plugin-architecture-boundary": "tsx scripts/ci/check-plugin-architecture-boundary.ts",
    "verify:runtime-artifact": "env -u NO_COLOR nx run sva-studio-react:verify:runtime-artifact",
    "test:release:studio": "pnpm test:pr && pnpm verify:runtime-artifact",
    "test:pr": "tsx scripts/ci/run-pr-gate.ts",
    "test:integration": "tsx scripts/ci/run-integration-gate.ts --mode full",
    "test:e2e": "env -u NO_COLOR nx run sva-studio-react:test:e2e",
    "test:acceptance:iam": "env -u NO_COLOR nx run sva-studio-react:test:acceptance",
    "test:evidence:iam": "env -u NO_COLOR nx run sva-studio-react:test:evidence",
    "test:acceptance:iam:performance": "env -u NO_COLOR nx run sva-studio-react:test:authorize-performance",
    "test:ci": "pnpm clean:generated-source-artifacts && pnpm check:file-placement && pnpm check:plugin-ui-boundary && pnpm check:plugin-architecture-boundary && pnpm check:openapi:iam && pnpm test:types && pnpm test:unit && pnpm test:coverage && pnpm complexity-gate && pnpm test:ops:critical",
    "coverage-gate": "tsx scripts/ci/coverage-gate.ts",
    "patch-coverage-gate": "tsx scripts/ci/patch-coverage-gate.ts",
    "sonar-new-code-gate": "tsx scripts/ci/sonar-new-code-gate.ts",
    "sonar:prepare-lcov": "tsx scripts/ci/prepare-sonar-lcov.ts",
    "complexity-gate": "tsx scripts/ci/complexity-gate.ts",
    "test:ops:instance-registry": "pnpm exec vitest run scripts/ops/instance-registry.test.ts",
    "test:ops:bootstrap-local-instance-db": "pnpm exec vitest run scripts/ops/bootstrap-local-instance-db.test.ts",
    "test:ops:local-instance-db-lifecycle": "pnpm exec vitest run scripts/ops/bootstrap-local-instance-db.test.ts scripts/ops/delete-local-instance-db.test.ts scripts/ops/runtime/rebuild-audit.test.ts",
    "test:ops:waste-calendar-example-pdf": "node --import tsx --test scripts/ops/waste-calendar-example-pdf.test.ts",
    "test:ops:critical": "pnpm test:ops:instance-registry && pnpm test:ops:local-instance-db-lifecycle && pnpm test:ops:waste-calendar-example-pdf",
    "clean:generated-source-artifacts": "tsx scripts/ci/clean-generated-source-artifacts.ts",
    "clean:source-artifacts": "pnpm clean:generated-source-artifacts",
    "check:file-placement": "tsx scripts/ci/check-file-placement.ts",
    "check:file-placement:staged": "tsx scripts/ci/check-file-placement.ts --staged",
    "check:openapi:iam": "tsx scripts/ci/check-openapi-iam.ts",
    "check:server-runtime": "env -u NO_COLOR NODE_OPTIONS=\"${NODE_OPTIONS:-} --import=./scripts/ci/node-listener-budget.mjs\" nx run-many -t check:runtime --parallel=1",
    "check:server-runtime:affected": "env -u NO_COLOR NODE_OPTIONS=\"${NODE_OPTIONS:-} --import=./scripts/ci/node-listener-budget.mjs\" nx affected --target=check:runtime --base=${NX_BASE:-origin/main} --parallel=1",
    "sonar:hotspots": "tsx scripts/ci/sonar-hotspots.ts",
    "sonar:hotspots:list": "tsx scripts/ci/sonar-hotspots.ts list",
    "env:up:local-keycloak": "tsx scripts/ops/runtime-env.ts up local-keycloak",
    "env:down:local-keycloak": "tsx scripts/ops/runtime-env.ts down local-keycloak",
    "env:update:local-keycloak": "tsx scripts/ops/runtime-env.ts update local-keycloak",
    "env:status:local-keycloak": "tsx scripts/ops/runtime-env.ts status local-keycloak",
    "env:smoke:local-keycloak": "tsx scripts/ops/runtime-env.ts smoke local-keycloak",
    "env:migrate:local-keycloak": "tsx scripts/ops/runtime-env.ts migrate local-keycloak",
    "env:doctor:local-keycloak": "tsx scripts/ops/runtime-env.ts doctor local-keycloak",
    "env:repair:local-keycloak": "tsx scripts/ops/runtime-env.ts repair local-keycloak",
    "env:reconcile:local-instance-registry": "tsx scripts/ops/runtime-env.ts reconcile local-keycloak",
    "env:verify:db-schema-snapshot": "tsx scripts/ops/runtime-env.ts verify-schema-snapshot local-keycloak",
    "env:bind:local-user": "tsx scripts/ops/bind-local-user.ts",
    "env:bootstrap:local-instance-db": "tsx scripts/ops/bootstrap-local-instance-db.ts",
    "env:delete:local-instance-db": "tsx scripts/ops/delete-local-instance-db.ts",
    "env:up:local-builder": "tsx scripts/ops/runtime-env.ts up local-builder",
    "env:down:local-builder": "tsx scripts/ops/runtime-env.ts down local-builder",
    "env:update:local-builder": "tsx scripts/ops/runtime-env.ts update local-builder",
    "env:status:local-builder": "tsx scripts/ops/runtime-env.ts status local-builder",
    "env:smoke:local-builder": "tsx scripts/ops/runtime-env.ts smoke local-builder",
    "env:migrate:local-builder": "tsx scripts/ops/runtime-env.ts migrate local-builder",
    "env:doctor:local-builder": "tsx scripts/ops/runtime-env.ts doctor local-builder",
    "env:status:studio": "tsx scripts/ops/runtime-env.ts status studio",
    "env:precheck:studio": "tsx scripts/ops/runtime-env.ts precheck studio",
    "env:deploy:studio": "tsx scripts/ops/runtime-env.ts deploy studio",
    "env:release:studio:local": "tsx scripts/ops/studio-release-local.ts",
    "env:feedback:studio": "tsx scripts/ops/deploy-feedback-loop.ts --latest",
    "env:smoke:studio": "tsx scripts/ops/runtime-env.ts smoke studio",
    "env:migrate:studio": "tsx scripts/ops/runtime-env.ts migrate studio",
    "env:reset:studio": "tsx scripts/ops/runtime-env.ts reset studio",
    "env:doctor:studio": "tsx scripts/ops/runtime-env.ts doctor studio",
    "schema-diff:sva-mainserver": "node scripts/ci/sva-mainserver-schema-diff.mjs",
    "benchmark:sva-mainserver": "node scripts/ops/benchmark-sva-mainserver.mjs",
    "iam:account-deletion-rules:run": "node --import tsx scripts/ops/run-iam-account-deletion-rules.mjs",
    "iam:retention:run": "node scripts/ops/run-iam-retention.mjs",
    "fallow:sync-skills": "tsx scripts/ops/sync-fallow-skills.ts",
    "i18n:format:resources": "tsx scripts/ops/format-i18n-resources.ts",
    "knip:scan": "knip -c knip.json --no-progress --no-exit-code --reporter compact",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smart-village-solutions/sva-studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/smart-village-solutions/sva-studio/issues"
  },
  "homepage": "https://github.com/smart-village-solutions/sva-studio#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^22.7.0",
    "@nx/eslint-plugin": "^22.7.0",
    "@nx/js": "^22.7.0",
    "@nx/playwright": "^22.7.0",
    "@nx/vite": "^22.7.0",
    "@nx/vitest": "^22.7.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "10.5.0",
    "eslint": "^10.3.0",
    "fallow": "2.90.0",
    "happy-dom": "^20.8.9",
    "knip": "^6.14.0",
    "nx": "22.7.4",
    "postcss": "8.5.11",
    "tailwindcss": "4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "prettier": "^3.8.4"
  }
}
