{
  "name": "data",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/data/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/data/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/data/src/**/*.{ts,tsx,js,jsx}"],
        "command": "pnpm --filter @sva/data exec tsc -p tsconfig.lib.json --noEmit"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "find packages/data/src -name '*.test.ts' ! -name '*.vitest.test.ts' -exec node --import tsx --test {} +"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @sva/data exec vitest run --coverage --reporter=verbose --config vitest.config.ts"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/test-seeds.sh"
      }
    },
    "db:up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d postgres"
      }
    },
    "db:down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose stop postgres"
      }
    },
    "db:status": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose ps postgres"
      }
    },
    "db:logs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose logs postgres --tail=200"
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/run-migrations.sh up"
      }
    },
    "db:migrate:up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/run-migrations.sh up"
      }
    },
    "db:migrate:down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/run-migrations.sh down"
      }
    },
    "db:migrate:validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/validate-migrations.sh"
      }
    },
    "db:seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/run-seeds.sh"
      }
    },
    "db:test:seeds": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/test-seeds.sh"
      }
    },
    "db:test:encryption": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/test-encryption.sh"
      }
    },
    "db:test:rls": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash packages/data/scripts/test-rls.sh"
      }
    },
    "db:reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose stop postgres && docker compose rm -f postgres && docker volume rm sva-studio_postgres-data || true"
      }
    }
  },
  "tags": ["scope:data", "type:lib"]
}
