{
  "name": "plugin-events",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-events/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/plugin-events/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "packages/plugin-events/src/**/*.{ts,tsx,js,jsx}",
          "packages/plugin-events/tests/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/plugin-events",
        "command": "pnpm exec vitest run tests --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/plugin-events",
        "command": "pnpm exec vitest run tests --coverage --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"console.log('no integration tests configured for @sva/plugin-events')\""
      }
    }
  },
  "tags": ["scope:plugin", "type:lib"]
}
