{
  "name": "plugin-news",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-news/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/plugin-news/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/plugin-news/src/**/*.{ts,tsx,js,jsx}"],
        "command": "pnpm --filter @sva/plugin-news exec tsc -p tsconfig.lib.json --noEmit"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"console.log('unit tests not configured for @sva/plugin-news (coverage-exempt)')\""
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"console.log('coverage tests not configured for @sva/plugin-news (coverage-exempt)')\""
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"console.log('integration tests not configured for @sva/plugin-news (coverage-exempt)')\""
      }
    }
  },
  "tags": ["scope:plugin", "type:lib"]
}
