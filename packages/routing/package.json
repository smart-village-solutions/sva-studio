{
  "name": "@sva/routing",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.server.d.ts",
      "default": "./dist/index.server.js"
    },
    "./auth": {
      "types": "./dist/auth.routes.d.ts",
      "default": "./dist/auth.routes.js"
    },
    "./guards": {
      "types": "./dist/guards.d.ts",
      "default": "./dist/guards.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "default": "./dist/plugins.js"
    }
  },
  "dependencies": {
    "@sva/auth": "workspace:*",
    "@sva/core": "workspace:*",
    "@sva/sdk": "workspace:*",
    "@tanstack/react-router": "^1.168.19"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
