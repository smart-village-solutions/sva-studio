{
  "name": "routing",
  "projectType": "library",
  "sourceRoot": "packages/routing/src",
  "prefix": "",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/routing/tsconfig.lib.json"
      }
    },
    "check:runtime": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm exec node --import tsx scripts/ci/check-server-package-runtime.ts --package routing"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/routing/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/routing",
        "command": "pnpm exec vitest run"
      },
      "configurations": {
        "watch": {
          "cwd": "packages/routing",
          "command": "pnpm exec vitest"
        }
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/routing",
        "command": "pnpm exec vitest run --coverage --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    }
  },
  "tags": ["type:lib", "scope:routing"]
}
