{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@sva/core": ["packages/core/dist/index.d.ts"],
      "@sva/monitoring-client": ["packages/monitoring-client/dist/index.d.ts"],
      "@sva/monitoring-client/logging": ["packages/monitoring-client/dist/logging.d.ts"],
      "@sva/monitoring-client/server": ["packages/monitoring-client/dist/server.d.ts"],
      "@sva/monitoring-client/logger-provider.server": ["packages/monitoring-client/dist/logger-provider.server.d.ts"],
      "@sva/plugin-sdk": ["packages/plugin-sdk/dist/index.d.ts"],
      "@sva/plugin-sdk/admin-resources": ["packages/plugin-sdk/dist/admin-resources.d.ts"],
      "@sva/server-runtime": ["packages/server-runtime/dist/index.d.ts"],
      "@sva/server-runtime/logger/index.server": ["packages/server-runtime/dist/logger/index.server.d.ts"],
      "@sva/server-runtime/logger/logging-runtime.server": [
        "packages/server-runtime/dist/logger/logging-runtime.server.d.ts"
      ],
      "@sva/server-runtime/logger/dev-log-buffer.server": [
        "packages/server-runtime/dist/logger/dev-log-buffer.server.d.ts"
      ],
      "@sva/server-runtime/middleware/request-context.server": [
        "packages/server-runtime/dist/middleware/request-context.server.d.ts"
      ],
      "@sva/server-runtime/observability/context.server": [
        "packages/server-runtime/dist/observability/context.server.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"]
}
