{
  "name": "studio-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/studio-mcp/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": { "command": "tsc -p packages/studio-mcp/tsconfig.lib.json" }
    },
    "check:runtime": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": { "command": "pnpm exec node --import tsx scripts/ci/check-server-package-runtime.ts --package studio-mcp" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["packages/studio-mcp/src/**/*.ts"] }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/studio-mcp",
        "command": "pnpm exec tsx ../../scripts/ci/run-vitest-target.ts --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:types": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/studio-mcp/tsconfig.lib.json --noEmit" }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/studio-mcp",
        "command": "pnpm exec tsx ../../scripts/ci/run-vitest-target.ts --coverage --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    }
  },
  "tags": ["scope:studio-mcp", "scope:instance-registry", "type:tool", "credentials:yes"]
}
