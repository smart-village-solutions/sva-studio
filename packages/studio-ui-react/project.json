{
  "name": "studio-ui-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/studio-ui-react/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/studio-ui-react/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "packages/studio-ui-react/src/**/*.{ts,tsx,js,jsx}",
          "packages/studio-ui-react/tests/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/studio-ui-react",
        "command": "pnpm exec vitest run --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/studio-ui-react/tsconfig.lib.json --noEmit"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/studio-ui-react",
        "command": "pnpm exec vitest run --coverage --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    }
  },
  "tags": ["scope:studio-ui-react", "type:lib"]
}
