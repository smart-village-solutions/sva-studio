{
  "name": "sva-mainserver",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/sva-mainserver/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/sva-mainserver/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/sva-mainserver/src/**/*.{ts,tsx,js,jsx}"],
        "command": "pnpm --filter @sva/sva-mainserver exec tsc -p tsconfig.lib.json --noEmit"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @sva/sva-mainserver exec vitest run --reporter=verbose --config vitest.config.ts"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @sva/sva-mainserver exec vitest run --coverage --reporter=verbose --config vitest.config.ts"
      }
    }
  },
  "tags": ["scope:integration", "type:lib"]
}
