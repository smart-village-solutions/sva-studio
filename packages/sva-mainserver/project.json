{
  "name": "sva-mainserver",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/sva-mainserver/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/sva-mainserver/tsconfig.lib.json"
      }
    },
    "check:runtime": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm exec node --import tsx scripts/ci/check-server-package-runtime.ts --package sva-mainserver"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/sva-mainserver/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/sva-mainserver",
        "command": "pnpm exec vitest run --reporter=verbose --config vitest.config.ts"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/sva-mainserver",
        "command": "pnpm exec vitest run --coverage --reporter=verbose --config vitest.config.ts"
      }
    }
  },
  "tags": ["scope:integration", "type:lib"]
}
