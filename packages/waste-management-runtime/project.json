{
  "name": "waste-management-runtime",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/waste-management-runtime/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "rm -rf packages/waste-management-runtime/dist packages/waste-management-runtime/tsconfig.lib.tsbuildinfo && tsc -p packages/waste-management-runtime/tsconfig.lib.json"
      }
    },
    "check:runtime": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm exec node --import tsx scripts/ci/check-server-package-runtime.ts --package waste-management-runtime"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "packages/waste-management-runtime/src/**/*.{ts,tsx,js,jsx}",
          "packages/waste-management-runtime/tests/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/waste-management-runtime",
        "command": "pnpm exec tsx ../../scripts/ci/run-vitest-target.ts tests --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/waste-management-runtime",
        "command": "pnpm exec tsx ../../scripts/ci/run-vitest-target.ts tests --coverage --reporter=verbose --config vitest.config.ts --passWithNoTests"
      }
    },
    "test:types": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p packages/waste-management-runtime/tsconfig.lib.json --noEmit"
      }
    }
  },
  "tags": ["scope:plugin-runtime", "type:lib"]
}
