{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sva/core": ["packages/core/src/index.ts"],
      "@sva/core/security": ["packages/core/src/security/index.ts"],
      "@sva/data": ["packages/data/src/index.ts"],
      "@sva/auth": ["packages/auth/src/index.ts"],
      "@sva/auth/server": ["packages/auth/src/index.server.ts"],
      "@sva/sdk": ["packages/sdk/src/index.ts"],
      "@sva/sdk/server": ["packages/sdk/src/server.ts"],
      "@sva/sdk/logger/index.server": ["packages/sdk/src/logger/index.server.ts"],
      "@sva/sdk/middleware/request-context.server": ["packages/sdk/src/middleware/request-context.server.ts"],
      "@sva/sdk/observability/context.server": ["packages/sdk/src/observability/context.server.ts"],
      "@sva/routing": ["packages/routing/src/index.ts"],
      "@sva/sva-mainserver": ["packages/sva-mainserver/src/index.ts"],
      "@sva/sva-mainserver/server": ["packages/sva-mainserver/src/index.server.ts"],
      "@sva/monitoring-client": ["packages/monitoring-client/src/index.ts"],
      "@sva/monitoring-client/server": ["packages/monitoring-client/src/server.ts"],
      "@sva/monitoring-client/logger-provider.server": ["packages/monitoring-client/src/logger-provider.server.ts"],
      "@sva/plugin-example": ["packages/plugin-example/src/index.ts"]
    }
  }
}
